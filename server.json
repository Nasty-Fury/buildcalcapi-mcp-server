{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "dev.buildcalcapi/server",
  "description": "Construction data API for AI agents: calculators, codes, costs, products, benchmarks.",
  "repository": {
    "url": "https://github.com/Nasty-Fury/buildcalc-api",
    "source": "github"
  },
  "version": "0.4.2",
  "remotes": [
    {
      "type": "streamable-http",
